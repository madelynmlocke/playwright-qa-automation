{
  "name": "playwright-qa-automation",
  "version": "1.0.0",
  "description": "![Playwright Tests](https://github.com/madelynmlocke/playwright-qa-automation/actions/workflows/playwright.yml/badge.svg) Playwright QA automation project covering UI, API, and end-to-end workflow testing with page objects, test data factories, defect reports, and CI.",
  "main": "playwright.config.js",
  "directories": {
    "test": "e2e"
  },
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test e2e/ui",
    "test:api": "playwright test e2e/api",
    "test:workflows": "playwright test e2e/workflows",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report",
    "test:smoke": "playwright test --grep @smoke",
    "test:debug": "playwright test --headed --debug",
    "test:regression": "playwright test --grep @regression",
    "test:negative": "playwright test --grep @negative"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/madelynmlocke/playwright-qa-automation.git"
  },
  "keywords": ["playwright", "qa", "test-automation", "api-testing", "e2e"],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/madelynmlocke/playwright-qa-automation/issues"
  },
  "homepage": "https://github.com/madelynmlocke/playwright-qa-automation#readme",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0"
  },
  "dependencies": {
    "dotenv": "^17.3.1"
  }
}
